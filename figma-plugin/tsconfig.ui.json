{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "types": ["vite/client", "@figma/plugin-typings"],
    "paths": {
      "@/*": ["./src/ui/*"],
      "@shared/*": ["./shared/*"],
      "@lib/*": ["./lib/*"]
    }
  },
  "include": [
    "src/ui/**/*",
    "shared/**/*",
    "lib/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/code.ts",
    "src/handlers/**/*",
    "src/extractors/**/*"
  ]
}