{
  "compilerOptions": {
    "target": "ES5",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES5", "DOM", "ES2015.Promise", "ES2015.Proxy"],
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "types": ["@figma/plugin-typings"],
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "importHelpers": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@handlers/*": ["src/handlers/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"],
      "@lib/*": ["src/lib/*"]
    }
  },
  "include": [
    "src/code.ts",
    "src/handlers/**/*",
    "src/utils/**/*",
    "src/types/**/*",
    "src/lib/**/*",
    "src/extractors/**/*",
    "src/validators/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/ui/**/*"
  ]
}