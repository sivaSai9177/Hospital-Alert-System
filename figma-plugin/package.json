{
  "name": "universal-design-system-figma-plugin",
  "version": "1.0.0",
  "description": "Figma plugin for syncing design tokens and components with Universal App codebase using MCP",
  "main": "dist/code.js",
  "scripts": {
    "dev": "concurrently \"bun run watch\" \"bun run ui:dev\"",
    "watch": "webpack --config webpack.config.es5.js --watch",
    "build": "bun run build:figma",
    "build:production": "node scripts/build-production.js",
    "build:pure-es5": "node scripts/build-pure-es5.js",
    "build:figma": "node scripts/build-figma-plugin.js",
    "clean": "rm -rf dist",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "lint": "eslint src/**/*.{ts,tsx} --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
